# INKD Edge Function secrets — copy to a real secret store; NEVER commit real keys.
# Set on Supabase with:  supabase secrets set --env-file supabase/functions/.env
#
# --- Stripe (Michael provides test keys) ---
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
#
# --- INKD tunables (optional; defaults shown) ---
INKD_FEE_BPS=1000          # application fee in basis points (1000 = 10%)
INKD_APP_URL=https://getinkd.co
STRIPE_CURRENCY=usd
#
# --- Auto-injected by the Supabase runtime; do NOT set these yourself ---
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
