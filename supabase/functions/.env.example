# INKD Edge Function secrets — copy to a real secret store; NEVER commit real keys.
# Set on Supabase with:  supabase secrets set --env-file supabase/functions/.env
#
# --- Stripe (Michael provides test keys) ---
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
#
# --- INKD tunables (optional; defaults shown) ---
INKD_FEE_BPS=1000          # application fee in basis points (1000 = 10%)
INKD_APP_URL=https://getinkd.co
STRIPE_CURRENCY=usd
#
# --- AI agent runtime (Michael provides the Anthropic key) ---
ANTHROPIC_API_KEY=sk-ant-replace_me   # required by agent-run AND tag-image (reused)
AGENT_MODEL=claude-sonnet-4-5         # optional; model for the AI staff
AGENT_MAX_TOKENS=1024                 # optional; per-run output cap
#
# --- AI image tagging (tag-image; reuses ANTHROPIC_API_KEY — NO new key) ---
TAG_MODEL=claude-sonnet-4-5           # optional; vision model (falls back to AGENT_MODEL)
TAG_MAX_TOKENS=700                    # optional; per-image classification cap
#
# --- Instagram import ("Instagram API with Instagram Login"; absent = every
#     instagram-* function except status/disconnect returns 503
#     instagram_not_configured) ---
INSTAGRAM_APP_ID=replace_me           # Instagram App ID from the Meta app's Instagram product
INSTAGRAM_APP_SECRET=replace_me       # Instagram App Secret (also the HMAC key for the signed OAuth state + Meta signed_request)
# PUBLIC_APP_URL=https://getinkd.co   # optional; base the OAuth callback + data-deletion redirect back to (defaults to getinkd.co)
# AGENT_RUNNER_TOKEN=replace_me       # optional; shared bearer the weekly instagram-refresh-tokens cron presents (falls back to the service-role key)
# The redirect URI is derived from SUPABASE_URL as
#   ${SUPABASE_URL}/functions/v1/instagram-oauth-callback
# and must match the Meta app's registered redirect URI exactly.
#
# --- Auto-injected by the Supabase runtime; do NOT set these yourself ---
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
