{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "INKD React Native (Expo)",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "ESNext"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "noEmit": true,
    "resolveJsonModule": true
  }
}
