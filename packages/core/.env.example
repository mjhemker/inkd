# @inkd/core reads Supabase config from platform-specific PUBLIC env vars.
# Copy the relevant pair into apps/web/.env.local or apps/mobile/.env.
#
# Real project URL (safe to commit); the anon key below is a PLACEHOLDER —
# get the real anon key from the Supabase dashboard and keep it out of git.

# --- Web (Next.js) ---
NEXT_PUBLIC_SUPABASE_URL=https://khlpidflnvkqafkvkpfy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# --- Mobile (Expo) ---
EXPO_PUBLIC_SUPABASE_URL=https://khlpidflnvkqafkvkpfy.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
