{
  "name": "@inkd/core",
  "version": "0.1.0",
  "private": true,
  "description": "INKD shared domain layer: typed Supabase client, env resolution, zod schemas, auth, data-access API, and TanStack Query hooks.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./supabase": {
      "types": "./src/supabase/index.ts",
      "default": "./src/supabase/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "default": "./src/auth/index.ts"
    },
    "./auth/web": {
      "types": "./src/auth/web.ts",
      "default": "./src/auth/web.ts"
    },
    "./auth/mobile": {
      "types": "./src/auth/mobile.ts",
      "default": "./src/auth/mobile.ts"
    },
    "./api": {
      "types": "./src/api/index.ts",
      "default": "./src/api/index.ts"
    },
    "./domain": {
      "types": "./src/domain/index.ts",
      "default": "./src/domain/index.ts"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "default": "./src/hooks/index.ts"
    },
    "./utils": {
      "types": "./src/utils/index.ts",
      "default": "./src/utils/index.ts"
    },
    "./waivers": {
      "types": "./src/waivers/index.ts",
      "default": "./src/waivers/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.48.1",
    "@tanstack/react-query": "^5.66.0",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@inkd/config": "workspace:*",
    "@types/react": "^19.0.7",
    "eslint": "^9.18.0",
    "react": "^19.1.0",
    "typescript": "^5.7.3"
  }
}
