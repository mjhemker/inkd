# Expo + React Native are not fully compatible with pnpm's symlinked node_modules.
# The hoisted linker gives an npm-like flat layout that Metro/Expo can resolve.
node-linker=hoisted

# Ensure common toolchain deps are hoisted to the root for CLIs that expect them.
# NOTE: tailwindcss is deliberately NOT hoisted — web uses v4, mobile/NativeWind
# uses v3, and each app must resolve its own major.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@expo/*
public-hoist-pattern[]=expo-*

# React Native ships prebuilt binaries; allow their install scripts.
enable-pre-post-scripts=true
