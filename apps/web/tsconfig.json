{
  "extends": "@inkd/config/tsconfig.nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    // Colocated *.test.ts run under `node --test` (type-stripping), which needs
    // explicit .ts import specifiers. Safe because Next typecheck is noEmit.
    "allowImportingTsExtensions": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
