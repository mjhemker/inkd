# Web (Next.js) environment. Copy to apps/web/.env.local and fill in the anon key.
# The URL is the real INKD Supabase project (safe to commit). The anon key is a
# PLACEHOLDER — pull the real one from the Supabase dashboard; never commit it.
NEXT_PUBLIC_SUPABASE_URL=https://khlpidflnvkqafkvkpfy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# --- Discovery map basemap (all OPTIONAL) -----------------------------------
# By default the map uses keyless OpenFreeMap tiles (liberty → positron) — no
# setup needed. Override only if you want a specific basemap.
#
# Option A — any MapLibre style URL (MapTiler, self-hosted, Stadia, …). Paste
# the full style.json URL including its key:
# NEXT_PUBLIC_MAP_STYLE_URL=https://api.maptiler.com/maps/streets-v2/style.json?key=YOUR_MAPTILER_KEY
#
# Option B — Mapbox. Paste ONLY your public token; the app rewrites mapbox://
# URLs to api.mapbox.com automatically (defaults to the dark-v11 style):
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token
# ...or pick a specific Mapbox style AND supply the token:
# NEXT_PUBLIC_MAP_STYLE_URL=mapbox://styles/mapbox/dark-v11
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token
