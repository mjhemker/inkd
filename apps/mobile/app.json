{
  "expo": {
    "name": "INKD",
    "slug": "inkd",
    "scheme": "inkd",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0A0A0B",
    "splash": {
      "backgroundColor": "#0A0A0B",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.getinkd.app"
    },
    "android": {
      "package": "co.getinkd.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0B"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
