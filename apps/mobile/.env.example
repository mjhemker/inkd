# Mobile (Expo) environment. Copy to apps/mobile/.env and fill in the anon key.
# The URL is the real INKD Supabase project (safe to commit). The anon key is a
# PLACEHOLDER — pull the real one from the Supabase dashboard; never commit it.
EXPO_PUBLIC_SUPABASE_URL=https://khlpidflnvkqafkvkpfy.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Optional. Full URL to the web app's /api/match-inspiration proxy (the
# bearer-gated tag-image step can't be called directly from mobile), e.g.
# https://getinkd.co/api/match-inspiration. When unset, the "Match my
# inspiration" screen shows a graceful "image search runs on the web app for
# now" state instead of the upload flow.
EXPO_PUBLIC_MATCH_INSPO_URL=

# Optional. Base URL the Instagram OAuth callback redirects back to — mirror the
# edge functions' PUBLIC_APP_URL. Only used as the auth-session redirect target
# (best-effort interception); connection state is always re-polled from
# instagram-status regardless. Defaults to https://getinkd.co when unset. Point
# at a preview/localhost during dev if the callback base is overridden there.
EXPO_PUBLIC_APP_URL=
